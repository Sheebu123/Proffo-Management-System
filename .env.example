# Copy this file to .env and fill in the actual values
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# For production, set a PostgreSQL URL.
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True
DB_SSLMODE=require

# Frontend origins allowed to call backend API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.vercel.app
CORS_ALLOWED_ORIGIN_REGEXES=
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.vercel.app,https://*.vercel.app

# Production security toggles (typically True in production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
DJANGO_LOG_LEVEL=INFO

# Gunicorn / Render tuning
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=50
